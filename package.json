{
  "name": "ai-powered-prompt-engineering-assistant",
  "description": "AI-Powered Prompt Engineering Assistant — multilingual prompt tool with grammar correction, speech-to-text, and OpenAI integration — by Poonam Tiwari",
  "author": "Poonam Tiwari",
  "license": "SEE LICENSE IN LICENSE FILE",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "keywords": [
    "react",
    "typescript",
    "openai",
    "prompt-engineering",
    "multilingual",
    "grammar-correction",
    "speech-to-text",
    "vite",
    "vitest"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:grammar": "vitest run --reporter=verbose src/test/grammar*.test.ts",
    "test:grammar:watch": "vitest --watch src/test/grammar*.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.344.0",
    "openai": "^5.20.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/ui": "^3.2.4",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "jsdom": "^27.0.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^3.2.4"
  }
}
